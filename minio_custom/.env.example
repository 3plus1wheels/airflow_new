MINIO_ROOT_USER=change-me-admin
MINIO_ROOT_PASSWORD=change-me-long-random-password
MINIO_DATA_DIR=./minio-data
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
POSTGRES_DB=minio_custom
POSTGRES_USER=minio_custom
POSTGRES_PASSWORD=change-me-long-random-postgres-password
POSTGRES_HOST_PORT=5432
DJANGO_SECRET_KEY=change-me-long-random-django-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DJANGO_CORS_ALLOW_CREDENTIALS=true
DJANGO_USE_X_FORWARDED_HOST=true
JWT_COOKIE_SECURE=false
JWT_COOKIE_SAMESITE=Lax
JWT_ACCESS_TOKEN_MINUTES=720
JWT_REFRESH_TOKEN_DAYS=14
VITE_API_BASE_URL=/api
